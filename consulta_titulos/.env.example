# Variables que esta app necesita. Van en el .env de la raíz `services/`
# (compartido con el resto de apps; NO se versiona). Aquí solo como referencia.

# --- Producción: apuntar al portal REAL de SENESCYT ---
SENESCYT_BASE_URL=https://www.senescyt.gob.ec
# El certificado SSL del portal real está roto -> desactivar verificación.
VERIFY_SSL=false

# --- Vigencia del caché (días). Por defecto 30. ---
CACHE_TTL_DIAS=30

# --- Compartidas con las demás apps (probablemente ya están en services/.env) ---
# Caché centralizada (Redis):
REDIS_URL=redis://localhost:6379/0
# Base con la tabla `api_keys` (mismo sistema de API keys del resto de servicios).
# Reutiliza la DATABASE_URL que ya usa el clasificador.
DATABASE_URL=postgresql://usuario:clave@host:5432/microservices_db

# -----------------------------------------------------------------------------
# DESARROLLO (contra el servidor mock local): en vez de lo de arriba, usar:
#   SENESCYT_BASE_URL=http://localhost:8090
#   VERIFY_SSL=true
